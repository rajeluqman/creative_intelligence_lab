# Copy to .env and fill. NEVER commit .env.
# Google Drive (client source folder) — service-account auth for headless ingestion.
# Share the client's Drive folder with the service account's client_email, then fill below.
GOOGLE_APPLICATION_CREDENTIALS=        # path to service-account JSON, NOT the JSON itself
DRIVE_FOLDER_ID=                       # the client's shared Drive folder id
CLIENT_ID=voltecx                      # THIS run's client slug — set to YOUR client, must match a row in seeds/dim_client.csv (no silent default; unset = dbt/script error)
# Storage = unified S3 (ADR-005, no MinIO). Real AWS for all layers.
S3_BUCKET=creative-intel-lake
S3_STAGING_BUCKET=creative-intel-staging   # throwaway: drills / overwrite work, never canonical
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PROMPT_VERSION=v1
# Serving (ADR-005): Snowflake Cortex veneer over Gold S3. DuckDB VSS = $0 fallback.
# Provision ONLY after v1 Gold has real rows + teardown plan (FinOps). Leave blank to use fallback.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_ROLE=
SERVING_BACKEND=duckdb_vss   # duckdb_vss (default, $0) | snowflake_cortex
# Operational notifications (ADR-009). Both optional — graceful no-op / fail-loud-on-real-run
# (not on parse) when unset; see dags/creative_intel_pipeline.py and scripts/sync_docs_to_confluence.py.
SLACK_WEBHOOK_URL=                     # Airflow task-failure alerts only (not CI, not budget — named OUT for now)
CONFLUENCE_BASE_URL=                   # e.g. https://yourcompany.atlassian.net/wiki
CONFLUENCE_EMAIL=                      # Confluence Cloud Basic Auth — Server/DC PAT auth not supported
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_PARENT_PAGE_ID=             # existing page these docs nest under as children
